generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.local.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  tier          String    @default("FREE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  projects   Project[]
  assets     Asset[]
  characters Character[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?
  fps          Int      @default(24)
  durationMs   Int      @default(30000)
  width        Int      @default(1920)
  height       Int      @default(1080)
  thumbnail    String?
  status       String   @default("DRAFT")
  version      Int      @default(1)
  timelineData String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes  Scene[]
  exports ExportJob[]

  @@index([userId])
  @@map("projects")
}

model Scene {
  id         String   @id @default(cuid())
  projectId  String
  name       String   @default("Scene 1")
  order      Int      @default(0)
  data       String   @default("{}")
  durationMs Int      @default(3000)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("scenes")
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  mimeType  String
  s3Key     String
  fileSize  Int
  width     Int?
  height    Int?
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assets")
}

model Character {
  id        String   @id @default(cuid())
  userId    String
  name      String
  shapeData String
  faceData  String
  limbsData String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("characters")
}

model ExportJob {
  id          String    @id @default(cuid())
  projectId   String
  format      String
  resolution  String    @default("1920x1080")
  status      String    @default("PENDING")
  progress    Float     @default(0)
  s3Key       String?
  error       String?
  watermark   Boolean   @default(true)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("export_jobs")
}
